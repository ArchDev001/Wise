        window._scanBroadcasts = function() {
            const container = document.getElementById('broadcast-list-container'); if(!container) return; container.style.display = 'flex'; container.innerHTML = '';
            let broadcasts = new Set();
            window.vm.runtime.targets.forEach(target => {
                for(let blockId in target.blocks._blocks) {
                    let block = target.blocks._blocks[blockId];
                    if(block.opcode === 'event_whenbroadcastreceived') {
                        let bName = block.fields.BROADCAST_OPTION.value;
                        if(bName) broadcasts.add(bName);
                    }
                    if(block.opcode === 'event_broadcast' || block.opcode === 'event_broadcastandwait') {
                         let input = block.inputs.BROADCAST_INPUT;
                         if(input && input.block) {
                             let innerBlock = target.blocks._blocks[input.block];
                             if(innerBlock && innerBlock.fields.BROADCAST_OPTION) broadcasts.add(innerBlock.fields.BROADCAST_OPTION.value);
                         }
                    }
                }
            });
            if(broadcasts.size === 0) { container.innerHTML = `<div style="font-size:12px; color:var(--w-subtext); text-align:center; padding: 10px 0;">${t('notFound')}</div>`; return; }
            Array.from(broadcasts).forEach(name => {
