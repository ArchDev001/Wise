            if(action === 'click') window._toggleClick(); if(action === 'trail') window._toggleTrail();
            if(action === 'filter') window._toggleFilter(); if(action === 'spoof') window._toggleSpoof();
            if(action === 'timerHack') window._toggleTimer(); if(action === 'cloneLimit') window._toggleCloneLimit();
            if(action === 'panic') window._panic();
        };

        window._updateSlider=function(el){
            if(!el)return;
            const val=(el.value-el.min)/(el.max-el.min)*100;
            el.style.background=`linear-gradient(to right, var(--w-main-color) ${val}%, var(--w-track) ${val}%)`;
        };

        window._toggleCard = function(btn) {
            const card = btn.closest('.w-card');
            const body = card.querySelector('.w-card-body');
            const isExpanded = card.classList.contains('w-expanded');
            if(!isExpanded){
                card.classList.add('w-expanded'); btn.style.transform = 'rotate(180deg)';
                if(card.id === 'card-varhack') window._scanVars();
                setTimeout(() => { if(card.classList.contains('w-expanded')) body.style.overflow = 'visible'; }, 300);
            } else {
                body.style.overflow = 'hidden'; body.querySelectorAll('.w-select-items').forEach(el => el.style.display = 'none');
                requestAnimationFrame(() => { card.classList.remove('w-expanded'); btn.style.transform = 'rotate(0deg)'; });
            }
        };

