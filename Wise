        window._updateKeybindsList = function() {
            const el = document.getElementById('w-keybinds-list');
            if(!el) return;
            if(!window.wState.keybindsList) { el.style.display = 'none'; return; }
            el.style.display = 'flex';
            let html = `<div class="w-kb-title">${t('keybindsList')}</div>`;
            let count = 0;
            for(let key in window.wBinds) {
                count++;
                let action = window.wBinds[key];
                let name = t(actionToName[action]) || action;
                let isOn = window.wState[action];
                let stateClass = isOn ? 'w-kb-on' : 'w-kb-off';
                html += `<div class="w-kb-item"><span class="${stateClass}">${name}</span> <span class="w-kb-key">[${formatKey(key)}]</span></div>`;
            }
            if(count===0) html += `<div style="font-size:11px; color:var(--w-subtext); text-align:center;">${t('notFound')}</div>`;
            el.innerHTML = html;
        };

