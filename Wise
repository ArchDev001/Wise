            for(let key in window.wLockedVars) {
                let parts = key.split('_locked_');
                if(parts.length !== 2) continue;
                let target = window.vm.runtime.targets.find(t=>t.id===parts[0]);
                if(target && target.variables[parts[1]]) {
                    target.variables[parts[1]].value = window.wLockedVars[key];
                }
            }
        }, 16);

