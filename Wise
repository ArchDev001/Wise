        window._toggleMenuBlur=function(forceState){ window.wState.menuBlur = typeof forceState === 'boolean' ? forceState : !window.wState.menuBlur; let cb = document.getElementById('menublur-toggle'); if(cb) cb.checked = window.wState.menuBlur; let isMenuOpen = !document.getElementById('w-client-gui').classList.contains('hidden'); let el = document.getElementById('w-menu-backdrop'); if(el) el.style.display = (window.wState.menuBlur && isMenuOpen) ? 'block' : 'none'; window._updateKeybindsList(); };
        window._toggleMenuSnow=function(forceState){ window.wState.menuSnow = typeof forceState === 'boolean' ? forceState : !window.wState.menuSnow; let cb = document.getElementById('menusnow-toggle'); if(cb) cb.checked = window.wState.menuSnow; let isMenuOpen = !document.getElementById('w-client-gui').classList.contains('hidden'); let el = document.getElementById('w-snow-canvas'); if(el) el.style.display = (window.wState.menuSnow && isMenuOpen) ? 'block' : 'none'; window._updateKeybindsList(); };
        window._toggleFilter=function(forceState){ window.wState.filter = typeof forceState === 'boolean' ? forceState : !window.wState.filter; let cb = document.getElementById('filter-toggle'); if(cb) cb.checked = window.wState.filter; const canvas=document.querySelector('canvas'); if(!canvas) return; if(window.wState.filter){ switch(window.wCurrentFilter){ case 'grayscale': canvas.style.filter='grayscale(100%)'; break; case 'invert': canvas.style.filter='invert(100%)'; break; case 'sepia': canvas.style.filter='sepia(100%)'; break; case 'contrast': canvas.style.filter='contrast(150%)'; break; case 'blur': canvas.style.filter='blur(3px)'; break; } } else { canvas.style.filter='none'; } window._updateKeybindsList(); };
        
        window._toggleCloneLimit=function(forceState){
            window.wState.cloneLimit = typeof forceState === 'boolean' ? forceState : !window.wState.cloneLimit;
            let cb = document.getElementById('clonelimit-toggle'); if(cb) cb.checked = window.wState.cloneLimit;
            if(window.wState.cloneLimit) {
                if(!window._origClonesAvailable && window.vm && window.vm.runtime) {
                    window._origClonesAvailable = window.vm.runtime.clonesAvailable;
                    window.vm.runtime.clonesAvailable = function() { return true; };
                }
            } else {
                if(window._origClonesAvailable && window.vm && window.vm.runtime) {
                    window.vm.runtime.clonesAvailable = window._origClonesAvailable;
                    window._origClonesAvailable = null;
                }
            }
            window._updateKeybindsList();
        };

        window._toggleSpoof = function(forceState) {
            window.wState.spoof = typeof forceState === 'boolean' ? forceState : !window.wState.spoof;
            let cb = document.getElementById('spoof-toggle'); if(cb) cb.checked = window.wState.spoof;
            if (!window._origGetUsername && window.vm && window.vm.runtime.ioDevices.userData) {
                window._origGetUsername = window.vm.runtime.ioDevices.userData.getUsername;
                window.vm.runtime.ioDevices.userData.getUsername = function() {
                    if (window.wState.spoof) { let input = document.getElementById('spoof-input'); return input ? (input.value || "Wise User") : "Wise User"; }
