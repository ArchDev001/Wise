        window._toggleDropdown = function(id, e) {
            if(e) e.stopPropagation();
            document.querySelectorAll('.w-select-items').forEach(el => {
                if(el.id !== 'items-'+id) {
                    el.style.display = 'none';
                    if(el.closest('.w-custom-select-container')) el.closest('.w-custom-select-container').style.zIndex = '1';
                    if(el.closest('.w-card')) el.closest('.w-card').style.zIndex = '';
                }
            });
            let el = document.getElementById('items-'+id);
            if(el) {
                if(el.style.display === 'block') {
                    el.style.display = 'none';
                    el.closest('.w-custom-select-container').style.zIndex = '1';
                    if(el.closest('.w-card')) el.closest('.w-card').style.zIndex = '';
                } else {
                    el.style.display = 'block';
                    el.closest('.w-custom-select-container').style.zIndex = '999';
                    if(el.closest('.w-card')) el.closest('.w-card').style.zIndex = '100'; 
                }
            }
        };

        window._selectOption = function(id, val, text, callbackStr) {
            let selectedEl = document.getElementById('selected-'+id);
            if(selectedEl) selectedEl.querySelector('span').innerText = text;
            let itemsEl = document.getElementById('items-'+id);
            if(itemsEl) {
                itemsEl.style.display = 'none';
                if(itemsEl.closest('.w-custom-select-container')) itemsEl.closest('.w-custom-select-container').style.zIndex = '1';
                if(itemsEl.closest('.w-card')) itemsEl.closest('.w-card').style.zIndex = ''; 
                itemsEl.querySelectorAll('div').forEach(d => d.classList.remove('active'));
                let act = Array.from(itemsEl.querySelectorAll('div')).find(d => d.innerText === text);
                if(act) act.classList.add('active');
            }
            eval(callbackStr);
        };

        document.addEventListener('click', function(e) {
            if(!e.target.closest('.w-custom-select-container')) {
                document.querySelectorAll('.w-select-items').forEach(el => {
                    el.style.display = 'none';
                    if(el.closest('.w-custom-select-container')) el.closest('.w-custom-select-container').style.zIndex = '1';
                    if(el.closest('.w-card')) el.closest('.w-card').style.zIndex = '';
                });
            }
            if(!e.target.closest('#btn-palette') && !e.target.closest('#w-accent-menu')) {
                let am = document.getElementById('w-accent-menu');
                if(am) am.style.display = 'none';
            }
        });

        function makeSelect(id, options, currentVal, onChangeFunc) {
            let currentText = options.find(o => o.val === currentVal)?.text || options[0].text;
            let itemsHtml = options.map(o => `<div onclick="window._selectOption('${id}', '${o.val}', '${o.text}', \`window.${onChangeFunc}('${o.val}')\`)" class="${o.val === currentVal ? 'active' : ''}">${o.text}</div>`).join('');
            return `<div class="w-custom-select-container"><div class="w-select-selected" id="selected-${id}" onclick="window._toggleDropdown('${id}', event)"><span>${currentText}</span><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M7 10l5 5 5-5z"/></svg></div><div class="w-select-items" id="items-${id}">${itemsHtml}</div></div>`;
