                                <div class="w-range-container" style="margin-top:15px;"><div class="w-range-labels"><span style="color:var(--w-subtext);">${t('clickWidth')}</span><span id="click-width-val">${clickEffectWidth}</span></div><input type="range" class="w-range" min="1" max="10" value="${clickEffectWidth}" oninput="document.getElementById('click-width-val').innerText = this.value; window._updateSlider(this); window._updateClickWidth(this.value);"></div>
                            </div>
                        </div>
                    </div>
                </div>
            `,
            user:()=>`
                <div class="w-tab-grid">
                    <div class="w-masonry-col">
                        <div class="w-card" id="card-spoof" data-bind="spoof">
                            <div class="w-card-header">
                                <div class="w-card-info"><div class="w-card-title">${t('spoof')} <span class="w-bind-badge" id="bind-badge-spoof"></span></div><div class="w-card-sub">${t('spoofSub')}</div></div>
                                <div class="w-card-controls"><label class="w-switch"><input type="checkbox" id="spoof-toggle" onchange="window._toggleSpoof(this.checked)"><span class="w-slider-toggle"></span></label><button class="w-expand-btn" onclick="window._toggleCard(this)"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg></button></div>
                            </div>
                            <div class="w-card-body">
                                <div style="display:flex; gap:6px;">
                                    <input type="text" id="spoof-input" class="w-var-input" style="flex:1; max-width:none; text-align:left; padding-left:10px;" placeholder="New username..." oninput="if(window.wState.spoof) window._updateHud()">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="w-masonry-col">
                        <div class="w-card" id="card-timerhack" data-bind="timerHack">
                            <div class="w-card-header">
                                <div class="w-card-info"><div class="w-card-title">${t('timerHack')} <span class="w-bind-badge" id="bind-badge-timerHack"></span></div><div class="w-card-sub">${t('timerHackSub')}</div></div>
                                <div class="w-card-controls"><label class="w-switch"><input type="checkbox" id="timer-toggle" onchange="window._toggleTimer(this.checked)"><span class="w-slider-toggle"></span></label><button class="w-expand-btn" onclick="window._toggleCard(this)"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg></button></div>
                            </div>
                            <div class="w-card-body">
                                <div style="display:flex; gap:6px;">
                                    <input type="number" id="timer-input" class="w-var-input" style="flex:1; max-width:none; text-align:left; padding-left:10px;" placeholder="Time in seconds (e.g. 0.0)">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `,
            misc:()=>`
                <div class="w-tab-grid">
                    <div class="w-masonry-col">
                        <div class="w-card">
                            <div class="w-card-header">
                                <div class="w-card-info"><div class="w-card-title">${t('menuBlur')}</div><div class="w-card-sub">${t('menuBlurSub')}</div></div>
                                <div class="w-card-controls"><label class="w-switch"><input type="checkbox" id="menublur-toggle" onchange="window._toggleMenuBlur(this.checked)"><span class="w-slider-toggle"></span></label></div>
                            </div>
                        </div>
                        <div class="w-card">
                            <div class="w-card-header">
                                <div class="w-card-info"><div class="w-card-title">${t('theme')}</div><div class="w-card-sub">${t('themeSub')}</div></div>
                                <div class="w-card-controls">
                                    ${makeSelect('theme-select', [
                                        {val: 'dark', text: t('dark')},
                                        {val: 'light', text: t('light')}
                                    ], currentTheme, '_setTheme')}
                                </div>
                            </div>
                        </div>
                        <div class="w-card" style="border-color:#ff4444;" data-bind="panic">
                            <div class="w-card-header">
                                <div class="w-card-info"><div class="w-card-title" style="color:#ff4444;">${t('panic')} <span class="w-bind-badge" id="bind-badge-panic"></span></div><div class="w-card-sub">${t('panicSub')}</div></div>
                                <div class="w-card-controls"><button class="w-btn" style="background:#ff4444;color:white;border:none;" onclick="window._panic()">EXECUTE</button></div>
                            </div>
                        </div>
                    </div>
                    <div class="w-masonry-col">
                        <div class="w-card">
                            <div class="w-card-header">
                                <div class="w-card-info"><div class="w-card-title">${t('menuSnow')}</div><div class="w-card-sub">${t('menuSnowSub')}</div></div>
                                <div class="w-card-controls"><label class="w-switch"><input type="checkbox" id="menusnow-toggle" onchange="window._toggleMenuSnow(this.checked)"><span class="w-slider-toggle"></span></label></div>
                            </div>
                        </div>
                        <div class="w-card">
                            <div class="w-card-header">
                                <div class="w-card-info"><div class="w-card-title">${t('language')}</div><div class="w-card-sub">${t('languageSub')}</div></div>
                                <div class="w-card-controls">
                                    ${makeSelect('lang-select', [
                                        {val: 'en', text: 'English'},
                                        {val: 'ru', text: 'Русский'},
                                        {val: 'uk', text: 'Українська'}
                                    ], currentLang, '_setLang')}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            `,
            configs:()=> {
                let html = `
                <div class="w-config-tabs">
                    <div class="w-config-tab ${window.wCurrentConfigTab === 'cloud' ? 'active' : ''}" onclick="window._switchConfigTab('cloud')"><div style="display:flex;align-items:center;justify-content:center;gap:6px;">${iconCloud} ${t('cloudConfigs')}</div></div>
                    <div class="w-config-tab ${window.wCurrentConfigTab === 'local' ? 'active' : ''}" onclick="window._switchConfigTab('local')"><div style="display:flex;align-items:center;justify-content:center;gap:6px;">${iconSave} ${t('localConfigs')}</div></div>
                </div>
                `;
                if(window.wCurrentConfigTab === 'local') {
                    html += `
                        <div style="display:flex; gap:10px; margin-bottom:15px;">
                            <button class="w-btn w-pill-primary" style="flex:1; justify-content:center; padding:10px; gap:6px;" onclick="window._showCreateConfig()">${iconPlus} ${t('createConfig')}</button>
                            <button class="w-btn" style="flex:1; justify-content:center; padding:10px; gap:6px;" onclick="window._showImportConfig()">${iconImport} ${t('importConfig')}</button>
                        </div>
                        <div id="local-configs-list" style="display:flex; flex-direction:column; gap:10px;"></div>
                    `;
                    setTimeout(window._renderConfigsList, 50);
                } else {
                    html += `<div style="text-align:center; color:var(--w-subtext); margin-top:30px; font-weight:600;">${t('cloudNotAvail')}</div>`;
                }
                return html;
            }
        };

        window._switchTab=function(tabId){
            currentTab=tabId;
            document.querySelectorAll('.w-tab, .w-bot-btn').forEach(t=>t.classList.remove('active'));
            if(document.getElementById(`tab-${tabId}`)) document.getElementById(`tab-${tabId}`).classList.add('active');
            if(document.getElementById(`btn-${tabId}`)) document.getElementById(`btn-${tabId}`).classList.add('active');
            
            let catMap = {'danger':'dangerCat', 'hud':'visualsCat', 'display':'visualsCat', 'user':'moreCat', 'misc':'settingsCat', 'configs':'settingsCat'};
            let tabMap = {'danger':'dangerTab', 'hud':'hudTab', 'display':'displayTab', 'user':'userTab', 'misc':'miscTab', 'configs':'configsTab'};

            if(tabId==='search') headerTitle.innerHTML=`<strong>${t('searchTitle')}</strong>`;
            else headerTitle.innerHTML=`${t(catMap[tabId])} / <strong>${t(tabMap[tabId])}</strong>`;
            
            if(tabId==='search'){
                let tempDiv = document.createElement('div');
                tempDiv.innerHTML = pages.danger() + pages.hud() + pages.display() + pages.user() + pages.misc();
                let col1HTML = ''; let col2HTML = ''; let i = 0;
                tempDiv.querySelectorAll('.w-card').forEach(card => {
                    if(i % 2 === 0) col1HTML += card.outerHTML;
                    else col2HTML += card.outerHTML;
                    i++;
                });
                contentArea.innerHTML=`<input type="text" id="global-search-input" class="w-search-box" placeholder="${t('search')}" oninput="window._filterGlobal(this.value)"><div class="w-tab-grid"><div class="w-masonry-col">${col1HTML}</div><div class="w-masonry-col">${col2HTML}</div></div>`;
            }else{
                contentArea.innerHTML=pages[tabId]();
            }
            
            document.querySelectorAll('input[type="range"]').forEach(el=>window._updateSlider(el));
            
            if(tabId==='danger'||tabId==='search'){
                let sp=document.getElementById('speed-toggle'); if(sp) sp.checked=window.wState.speed;
                let cl=document.getElementById('clonelimit-toggle'); if(cl) cl.checked=window.wState.cloneLimit;
            }
            if(tabId==='hud'||tabId==='search'){
                let ht=document.getElementById('watermark-toggle'); if(ht) ht.checked=window.wState.watermark;
                let kt=document.getElementById('keys-toggle'); if(kt) kt.checked=window.wState.keys;
                let kb=document.getElementById('keybinds-toggle'); if(kb) kb.checked=window.wState.keybindsList;
            }
            if(tabId==='display'||tabId==='search'){
                let ct=document.getElementById('click-toggle'); if(ct) ct.checked=window.wState.click;
                let tr=document.getElementById('trail-toggle'); if(tr) tr.checked=window.wState.trail;
                let cc=document.getElementById('click-color'); if(cc) cc.value=clickEffectColor;
                let tc=document.getElementById('trail-color'); if(tc) tc.value=trailEffectColor;
                let ft=document.getElementById('filter-toggle'); if(ft) ft.checked=window.wState.filter;
            }
            if(tabId==='user'||tabId==='search'){
                let st=document.getElementById('spoof-toggle'); if(st) st.checked=window.wState.spoof;
                let tt=document.getElementById('timer-toggle'); if(tt) tt.checked=window.wState.timerHack;
                let si = document.getElementById('spoof-input');
                let ti = document.getElementById('timer-input');
                if(si && !si.value && window.wState.spoofName) si.value = window.wState.spoofName;
                if(ti && !ti.value && window.wState.timerVal) ti.value = window.wState.timerVal;
            }
            if(tabId==='misc'||tabId==='search'){
                let mb=document.getElementById('menublur-toggle'); if(mb) mb.checked=window.wState.menuBlur;
                let ms=document.getElementById('menusnow-toggle'); if(ms) ms.checked=window.wState.menuSnow;
                let ac=document.getElementById('accent-color'); if(ac) ac.value=getComputedStyle(document.documentElement).getPropertyValue('--w-main-color').trim();
            }
            
            window._updateBindBadges();
            if(tabId==='search') setTimeout(()=>document.getElementById('global-search-input')?.focus(),50);
        };

        const makeDrag=function(id){
            const el=document.getElementById(id);
            if(!el) return;
            let isDrag=false,ox=0,oy=0;
            el.addEventListener('mousedown',e=>{
                if(!el.classList.contains('w-editing'))return;
                isDrag=true;
                let rect=el.getBoundingClientRect();
                ox=e.clientX-rect.left;
                oy=e.clientY-rect.top;
                e.preventDefault();
            });
            document.addEventListener('mousemove',e=>{
                if(!isDrag)return;
                let nx=e.clientX-ox;
                let ny=e.clientY-oy;
                
                if(window.wAlignmentEnabled){
                    let otherIds = ['w-client-hud', 'w-keystrokes', 'w-keybinds-list'].filter(i => i !== id);
                    let snapped=false;
                    for(let oid of otherIds) {
                        let otherEl=document.getElementById(oid);
                        if(otherEl && otherEl.style.display !== 'none'){
                            let otherRect=otherEl.getBoundingClientRect();
                            if(Math.abs(nx-otherRect.left)<15){
                                nx=otherRect.left;
                                window._showGuideX(nx);
                                snapped=true;
                                break;
                            }
                        }
                    }
                    if(!snapped && Math.abs(nx-12)<15){
                        nx=12;
                        window._showGuideX(12);
                        snapped=true;
                    }
                    if(!snapped) window._hideGuideX();
                }

                el.style.left=nx+'px';
                el.style.top=ny+'px';
                el.style.right='auto';
                el.style.bottom='auto';
            });
            document.addEventListener('mouseup',()=>{
                isDrag=false;
                window._hideGuideX();
            });
        };
        makeDrag('w-client-hud');
        makeDrag('w-keystrokes');
        makeDrag('w-keybinds-list');

        const wOnMouseMove = (e)=>{
            window.mouseX=e.clientX;
            window.mouseY=e.clientY;
            window._updateHud();
        };

        const keyMap={'KeyW':'k-w','KeyA':'k-a','KeyS':'k-s','KeyD':'k-d','Space':'k-space'};
        
        const wOnKeyDown = (e)=>{
            if(window.wIsBinding) {
                e.preventDefault();
                e.stopPropagation();
                if(e.code !== 'Escape') {
                    let oldKey = Object.keys(window.wBinds).find(k => window.wBinds[k] === window.wCurrentBindId);
                    if(oldKey) delete window.wBinds[oldKey];
                    window.wBinds[e.code] = window.wCurrentBindId;
                }
                window._closeBindModal();
                window._updateBindBadges();
                window._updateKeybindsList();
                return;
            }

            if(window.wBinds && window.wBinds[e.code]) {
                e.preventDefault();
                window._executeBind(window.wBinds[e.code]);
            }

            if(keyMap[e.code])document.getElementById(keyMap[e.code])?.classList.add('active');
            if(e.code==='AltRight'){
                e.preventDefault();
                gui.classList.toggle('hidden');
                let isMenuOpen = !gui.classList.contains('hidden');
                if (window.wState.menuBlur) document.getElementById('w-menu-backdrop').style.display = isMenuOpen ? 'block' : 'none';
                if (window.wState.menuSnow) document.getElementById('w-snow-canvas').style.display = isMenuOpen ? 'block' : 'none';
            }
        };

        const wOnKeyUp = (e)=>{
            if(keyMap[e.code])document.getElementById(keyMap[e.code])?.classList.remove('active');
        };
        
        const wOnMouseDown = (e)=>{
            if(e.button === 1) { 
                let bindEl = e.target.closest('[data-bind]');
                if(bindEl) {
                    e.preventDefault();
                    let titleEl = bindEl.querySelector('.w-setting-title') || bindEl.querySelector('.w-card-title');
                    let titleText = titleEl ? titleEl.innerText.replace(/\[.*?\]/g, '').trim() : "Function";
                    window._openBindModal(bindEl.dataset.bind, titleText);
                }
            }

            if(e.button===0)document.getElementById('k-lmb')?.classList.add('active');
            if(e.button===2)document.getElementById('k-rmb')?.classList.add('active');
            if(!window.wState.click)return;
            if(e.target.closest('#w-client-gui') || window.wIsBinding || e.target.closest('#w-action-modal'))return;
            
            const ripple=document.createElement('div');
            ripple.className='w-click-ripple';
            ripple.style.left=`${e.clientX}px`;
            ripple.style.top=`${e.clientY}px`;
            ripple.style.borderColor=clickEffectColor;
            document.body.appendChild(ripple);
            setTimeout(()=>ripple.remove(),600);
        };
        
        const wOnMouseUp = (e)=>{
            if(e.button===0)document.getElementById('k-lmb')?.classList.remove('active');
            if(e.button===2)document.getElementById('k-rmb')?.classList.remove('active');
        };

        document.addEventListener('mousemove', wOnMouseMove);
        document.addEventListener('keydown', wOnKeyDown);
        document.addEventListener('keyup', wOnKeyUp);
        document.addEventListener('mousedown', wOnMouseDown);
        document.addEventListener('mouseup', wOnMouseUp);

        const handle=document.getElementById('w-drag-handle');
        let isDraggingGui=false,gox=0,goy=0;
        handle.addEventListener('mousedown',(e)=>{
            if(e.button !== 0) return;
            isDraggingGui=true;
            const rect=gui.getBoundingClientRect();
            gox=e.clientX-rect.left;
            goy=e.clientY-rect.top;
        });
        document.addEventListener('mousemove',(e)=>{
            if(!isDraggingGui)return;
            e.preventDefault();
            gui.style.left=(e.clientX-gox)+'px';
            gui.style.top=(e.clientY-goy)+'px';
        });
        document.addEventListener('mouseup',()=>isDraggingGui=false);

        window._switchTab('danger');
    }
})();
